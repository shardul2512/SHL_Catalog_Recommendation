# Copy to .env (locally) or set these in Render's dashboard as env vars.

# groq | openrouter | gemini | custom
LLM_PROVIDER=groq

# Only the one matching LLM_PROVIDER is required. Get a free key at:
#   Groq:       https://console.groq.com/keys
#   OpenRouter: https://openrouter.ai/keys
#   Gemini:     https://aistudio.google.com/apikey
GROQ_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Optional overrides (sane defaults are set in app/config.py)
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_FALLBACK_MODEL=llama-3.1-8b-instant
# LLM_BASE_URL=
# LLM_TIMEOUT_SECONDS=18
# RETRIEVAL_TOP_K=28
# MAX_TURNS=8
